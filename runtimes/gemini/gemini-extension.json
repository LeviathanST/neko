{
  "name": "neko",
  "version": "0.1.0",
  "description": "Neko — A Personalized-First AI Partner with personality, memory, and reflection",
  "mcpServers": {
    "neural-memory": {
      "command": "nmem-mcp",
      "env": {
        "NMEM_BRAIN": "neko"
      },
      "trust": true
    }
  },
  "contextFileName": "NEKO.md",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Neko session started. Read brain/REFLECTION.md and run nmem_recall to load context.'",
            "name": "Neko session bootstrap"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/session-end-save.sh",
            "name": "Neko session save",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
